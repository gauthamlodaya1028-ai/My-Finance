# Copy to .env and fill in. Leave a var unset to disable that feature.
# Local dev with NOTHING set → SQLite + no auth + chat via local `claude` CLI.

# === BACKEND: pick Appwrite OR Supabase/SQLite ===
# If APPWRITE_* are set, the app uses Appwrite (TablesDB + Appwrite Auth) for
# BOTH database and login, and the Supabase/SQLite settings below are ignored.
# Run `node appwrite-setup.js` once to create tables, then `node migrate-to-appwrite.js`.
APPWRITE_ENDPOINT=        # e.g. https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT=         # project ID
APPWRITE_API_KEY=         # server API key (Databases + Users scopes) — secret
APPWRITE_DB=finance       # database id (created by appwrite-setup.js)
# Also add a Web platform in Appwrite (Integrations → Platforms → Web) with your
# hostname (localhost for dev, your domain for prod) or browser login is CORS-blocked.

# --- Database (production, Supabase path — only if NOT using Appwrite) ---
# Supabase Postgres connection string. Use the POOLER (Supavisor) URI, transaction
# mode, port 6543 — it's IPv4 and works from most hosts. Supabase dashboard →
# Project Settings → Database → Connection string → "Transaction pooler".
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Auth (production) ---
# Supabase Project URL + anon (public) key. Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Restrict the app to a single email (your login). Leave blank to allow any signed-in user.
ALLOWED_EMAIL=

# --- Chat assistant (pick ONE auth method) ---
# Option A: Anthropic API key (pay-per-use, reliable on a server, no expiry).
ANTHROPIC_API_KEY=
# Option B: OAuth bearer token from your Max/Pro subscription (no per-use cost).
#   ⚠️ Short-lived (~1h) and NOT auto-refreshed here — the server's chat stops
#   working when it expires unless you re-paste or run a refresher. Also a gray
#   area on Anthropic's terms for custom hosted apps. Get a token with:
#     claude setup-token        (or: ant auth login && ant auth print-credentials --access-token)
# If ANTHROPIC_API_KEY is set it wins; if both are empty, chat uses the local `claude` CLI.
ANTHROPIC_AUTH_TOKEN=
# Option C (what you're using): run the logged-in `claude` CLI on the host — it
# auto-refreshes OAuth itself. Leave both vars above empty. If `claude` isn't on
# the server PATH, set its absolute path here (find it with `which claude`).
CLAUDE_BIN=
# Which Claude account/subscription the chat uses. Point at a config dir you've
# logged into the desired account (CLAUDE_CONFIG_DIR=DIR claude → /login). This
# isolates the app's chat account from any other `claude` login on the host.
CLAUDE_CONFIG_DIR=
# Model. Default claude-opus-4-8 (~$5/$25 per Mtok). You chose Sonnet:
CHAT_MODEL=claude-sonnet-4-6

# --- Server ---
PORT=3000
