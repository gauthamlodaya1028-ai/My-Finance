# Copy to .env and fill in. Leave a var unset to disable that feature.
# Local dev with NOTHING set → SQLite + no auth + chat via local `claude` CLI.

# --- Database (production) ---
# Supabase Postgres connection string. Use the POOLER (Supavisor) URI, transaction
# mode, port 6543 — it's IPv4 and works from most hosts. Supabase dashboard →
# Project Settings → Database → Connection string → "Transaction pooler".
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Auth (production) ---
# Supabase Project URL + anon (public) key. Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Restrict the app to a single email (your login). Leave blank to allow any signed-in user.
ALLOWED_EMAIL=

# --- Chat assistant ---
# Anthropic API key. If set, chat uses the API; if unset, it falls back to the
# local `claude` CLI (your Max plan) — which only works on your own machine.
ANTHROPIC_API_KEY=
# Optional model override. Default claude-opus-4-8 (~$5/$25 per Mtok).
# Cheaper options: claude-sonnet-4-6 ($3/$15) or claude-haiku-4-5 ($1/$5).
CHAT_MODEL=

# --- Server ---
PORT=3000
